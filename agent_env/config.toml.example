[run]
split = "easy"
method = "codex_cli"
work_dir = "agent_env/runs"
tool_python = "UV_CACHE_DIR=/tmp/uv_cache uv run python"
uid = ""
limit = 1
no_run_codex = false
resume = false
plan_file = ""

[codex]
model = "gpt-5.5"
timeout = 900
sandbox = "workspace-write"
output_schema = false
require_output_tags = true

# Keep the real config.toml untracked because this may contain a secret.
# Either set api_key here in your local config.toml, or leave it empty and
# export the env var named by api_key_env before running the script.
api_key = ""
api_key_env = "OPENAI_API_KEY"

[codex.provider]
id = "openai_api"
name = "OpenAI API"
base_url = "https://api.openai.com/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"

[codex.extra_config]
model_reasoning_effort = "low"
model_verbosity = "low"
