[run]
split = "easy"
harness = "opencode"
method = ""
work_dir = ""
tool_python = "UV_CACHE_DIR=/tmp/uv_cache uv run python"
uid = ""
limit = 1
no_run_harness = false
resume = false
plan_file = ""

[opencode]
model = "dashscope/qwen3.6-27b"
timeout = 900
require_output_tags = true
dangerously_skip_permissions = true

# Keep the real config.toml untracked because this may contain a secret.
# Either set api_key here in your local config.toml, or leave it empty and
# export the env var named by api_key_env before running the script.
api_key = ""
api_key_env = "DASHSCOPE_API_KEY"

[opencode.provider]
id = "dashscope"
name = "DashScope"
npm = "@ai-sdk/openai-compatible"
base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
tool_call = true

[opencode.provider.model_options]
enable_thinking = false

[codex]
model = "qwen3.6-35b-a3b"
timeout = 900
sandbox = "workspace-write"
output_schema = false
require_output_tags = true
api_key = ""
api_key_env = "OPENAI_API_KEY"

[codex.provider]
id = "openai_api"
name = "OpenAI API"
base_url = "https://api.openai.com/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"

[codex.extra_config]
model_reasoning_effort = "low"
model_verbosity = "low"
